# Copy this file to .env and fill in your values
# NEVER commit .env — it is gitignored

# App / Security
JWT_SECRET=
TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000/

# App URLs
FRONTEND_URL=http://localhost:3000/
NEXT_PUBLIC_API_URL=http://localhost:3000/

# Google / OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_MOBILE_CLIENT_ID=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# Cloudinary
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase
API_KEY=
FIREBASE_SERVICE_ACCOUNT=

# Mail (Mailjet)
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
MAILJET_FROM_EMAIL=
MAILJET_FROM_NAME=

MAILJET_NOTIFICATION_API_KEY=
MAILJET_NOTIFICATION_SECRET_KEY=
MAILJET_NOTIFICATION_FROM_EMAIL=

# SMTP (Brevo)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
BREVO_SENDER_EMAIL=
BREVO_API_KEY=

# Database (AWS RDS / PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_READ_URL=
NEW_DATABASE_URL=
ECOM_DATABASE_URL=
WTSP_DATABASE_URL=
AWS_RDS_DB_NAME=
AWS_RDS_DB_USER=
AWS_RDS_DB_PASSWORD=
AWS_RDS_WRITER_HOST=
AWS_RDS_READER_HOST=
AWS_RDS_PORT=5432

# Supabase
SUPABASE_DB_SSL=true
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=

# Redis / Upstash
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AI
BAZAAR_API_KEY=
GOOGLE_GEMINI_API_KEY=
GOOGLE_GEMINI_MODEL=gemini-flash-latest

# Real-time WebSocket
REALTIME_PORT=3001
REALTIME_EMITTER_PORT=3002
REALTIME_EMITTER_URL=http://localhost:3002
REALTIME_INTERNAL_KEY=
NEXT_PUBLIC_REALTIME_URL=http://localhost:3001

# AWS S3 & CloudFront
AWS_S3_REGION=
AWS_S3_BUCKET_SOCIAL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_CLOUDFRONT_DOMAIN=
AWS_S3_BUCKET_MAIN=

# Video Pipeline (MediaConvert)
AWS_S3_BUCKET_VIDEOS_RAW=
AWS_S3_BUCKET_VIDEOS_HLS=
AWS_MEDIACONVERT_ENDPOINT=
AWS_MEDIACONVERT_ROLE_ARN=
AWS_CLOUDFRONT_VIDEO_DOMAIN=
VIDEO_WEBHOOK_SECRET=

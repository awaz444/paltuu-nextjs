  added_at                DateTime?                @default(now()) @db.Timestamp(6)
  updated_at              DateTime?                @default(now()) @db.Timestamp(6)
  vendor_id               BigInt?
  inventory_id            BigInt?
  vendor_inventory        vendor_inventory?        @relation(fields: [inventory_id], references: [inventory_id], onUpdate: NoAction)
  vendors                 vendors?                 @relation(fields: [vendor_id], references: [vendor_id], onUpdate: NoAction)
  bazaar_carts            bazaar_carts             @relation(fields: [cart_id], references: [cart_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cart_item_cart")
  bazaar_products         bazaar_products          @relation(fields: [product_id], references: [product_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cart_item_product")
